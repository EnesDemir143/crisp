  local stars_script="$CRISP_MODULES_DIR/stars.sh"
  if [ -f "$stars_script" ]; then
    source "$stars_script"
    crisp_stars_run
  else
    echo -e "  ${RED}вң— stars module not found${RST}"
  fi
