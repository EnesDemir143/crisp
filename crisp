# ---- interactive menu loop -------------------------------------------------
_interactive_menu() {
  # Only show interactive menu if stdout is a terminal
  if [ ! -t 1 ]; then
    echo "crisp: interactive menu requires a terminal"
    exit 1
  fi

  local n; n=$(_menu_count)
  local sel=0
  local id key

  # Draw header once, then menu area
  _draw_header
  _draw_menu_area $sel

  while true; do
    key=$(read_key)

    case "$key" in
      UP)
        sel=$(( (sel - 1 + n) % n ))
        _back_to_menu
        _draw_menu_area $sel
        ;;
      DOWN)
        sel=$(( (sel + 1) % n ))
        _back_to_menu
        _draw_menu_area $sel
        ;;
      TOP)
        sel=0
        _back_to_menu
        _draw_menu_area $sel
        ;;
      ENTER)
        id=$(_get_menu_item $sel id)
        show_cursor
        _dispatch_menu "$id"
        # Full redraw after sub-action
        _draw_header
        _draw_menu_area $sel
        hide_cursor
        ;;
      NUM:*)
        local num="${key#NUM:}"
        if [ "$num" -ge 1 ] && [ "$num" -le "$n" ]; then
          sel=$((num - 1))
          id=$(_get_menu_item $sel id)
          show_cursor
          _dispatch_menu "$id"
          _draw_header
          _draw_menu_area $sel
          hide_cursor
        fi
        ;;
      VERSION)
        clear_screen
        echo
        echo -e "  ${BOLD}crisp v${CRISP_VERSION}${RST}"
        echo -e "  ${DIM}${CRISP_TAGLINE}${RST}"
        echo -e "  ${DIM}Config: ${CRISP_CONF}${RST}"
        echo -e "  ${DIM}Modules: ${CRISP_MODULES_DIR}/${RST}"
        echo
        echo -e "  ${DIM}Active: ${CRISP_MODULES}${RST}"
        echo
        echo -e "  ${DIM}Press any key to return...${RST}"
        read -r -s -n 1
        _draw_header
        _draw_menu_area $sel
        ;;
      HELP)
        show_cursor
        _show_help_screen
        echo
        echo -e "  ${DIM}Press any key to return...${RST}"
        read -r -s -n 1
        hide_cursor
        _draw_header
        _draw_menu_area $sel
        ;;
      QUIT|ESC)
        clear_screen
        show_cursor
        echo
        echo -e "  ${DIM}crisp вҖ” see you soon!${RST}"
        echo
        exit 0
        ;;
    esac
  done
}

