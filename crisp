}

# ---- cron schedule sub-menu ------------------------------------------------
CRON_PRESETS=(
  "every_5m:Every 5 minutes:Every 5 minutes"
  "every_15m:Every 15 minutes:Every 15 minutes"
  "every_30m:Every 30 minutes:Every 30 minutes"
  "every_1h:Every 1 hour:Every hour"
  "every_6h:Every 6 hours:Every 6 hours"
  "daily_09:Daily at 09:00:Daily at 09:00"
  "weekly_mon:Weekly (Monday 09:00):Every Monday at 09:00"
  "monthly_1:Monthly (1st, 03:00):1st of each month at 03:00"
  "custom:Custom cron expression:Custom cron expression"
)

_cron_preset_count() { echo "${#CRON_PRESETS[@]}"; }

_cron_get_item() {
  local idx=$1 field=$2
  local item="${CRON_PRESETS[$idx]}"
  case $field in
    id)    echo "$item" | cut -d: -f1 ;;
    title) echo "$item" | cut -d: -f2 ;;
    desc)  echo "$item" | cut -d: -f3 ;;
  esac
}

_cron_expression() {
  case "$1" in
    every_5m)    echo "*/5 * * * *" ;;
    every_15m)   echo "*/15 * * * *" ;;
    every_30m)   echo "*/30 * * * *" ;;
    every_1h)    echo "0 * * * *" ;;
    every_6h)    echo "0 */6 * * *" ;;
    daily_09)    echo "0 9 * * *" ;;
    weekly_mon)  echo "0 9 * * 1" ;;
    monthly_1)   echo "0 3 1 * *" ;;
    *)           echo "" ;;
  esac
}

_menu_cron_schedule() {
  local cron_selection=0
  local cron_n; cron_n=$(_cron_preset_count)

  while true; do
    clear_screen

    echo
    echo -e "  ${BOLD}${BCYN}crisp cron${RST} ${BOLD}вҖ” auto-update scheduler${RST}"
    echo -e "  ${DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RST}"
    echo
    echo -e "  ${DIM}How often should it run?${RST}"
    echo

    for ((i=0; i<cron_n; i++)); do
      local title="$(_cron_get_item $i title)"
      local desc="$(_cron_get_item $i desc)"

      if [ $i -eq $cron_selection ]; then
        echo -e "  ${BCYN}в–¶ ${title}${RST}"
        echo -e "     ${DIM}${desc}${RST}"
      else
        echo -e "  ${DIM}  ${title}${RST}"
        echo -e "     ${DIM}${desc}${RST}"
      fi
      echo
    done

    echo
    echo -e "  ${DIM}вҶ‘/вҶ“: select  в”Ӯ  Enter: confirm  в”Ӯ  q: back${RST}"
    echo

    local key; key=$(read_key)

    case "$key" in
      UP)
        cron_selection=$(( (cron_selection - 1 + cron_n) % cron_n ))
        ;;
      DOWN)
        cron_selection=$(( (cron_selection + 1) % cron_n ))
        ;;
      ENTER)
        local cron_id="$(_cron_get_item $cron_selection id)"

        if [ "$cron_id" = "custom" ]; then
          _cron_custom_input
        else
          local expr; expr=$(_cron_expression "$cron_id")
          local title; title="$(_cron_get_item $cron_selection title)"
          _schedule_cron_job "$title" "$expr"
        fi
        return
        ;;
      QUIT|ESC)
        return
        ;;
    esac
  done
}

_cron_custom_input() {
  clear_screen
  echo
  echo -e "  ${BOLD}${BCYN}crisp cron${RST} ${BOLD}вҖ” custom cron expression${RST}"
  echo -e "  ${DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RST}"
  echo
  echo -e "  ${DIM}Format: minute hour day month weekday${RST}"
  echo -e "  ${DIM}Examples:${RST}"
  echo -e "  ${DIM}  */15 * * * *    вҶ’ every 15 minutes${RST}"
  echo -e "  ${DIM}  0 */2 * * *     вҶ’ every 2 hours${RST}"
  echo -e "  ${DIM}  0 9 * * 1-5     вҶ’ weekdays at 9 AM${RST}"
  echo -e "  ${DIM}  0 0 1 * *       вҶ’ 1st of month, midnight${RST}"
  echo

  printf "  ${BCYN}Cron expression: ${RST}"
  read -r custom_expr

  if [ -z "$custom_expr" ]; then
    echo -e "  ${YEL}вҡ  Cancelled${RST}"
    sleep 1
    return
  fi

  _schedule_cron_job "Custom: $custom_expr" "$custom_expr"
}

_schedule_cron_job() {
  local title="$1" expr="$2"

  # Check if hermes CLI is available
  if ! command -v hermes &>/dev/null; then
    clear_screen
    echo
    echo -e "  ${BOLD}${BCYN}crisp cron${RST} ${BOLD}вҖ” schedule confirmation${RST}"
    echo -e "  ${DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RST}"
    echo
    echo -e "  ${RED}вң— Hermes CLI not found!${RST}"
    echo
    echo -e "  ${DIM}Hermes Agent is required for cron scheduling.${RST}"
    echo -e "  ${DIM}Kurulum: https://hermes-agent.nousresearch.com${RST}"
    echo
    echo -e "  ${DIM}Press any key to return...${RST}"
    read -r -s -n 1
    return 1
  fi

  clear_screen
  echo
  echo -e "  ${BOLD}${BCYN}crisp cron${RST} ${BOLD}вҖ” schedule confirmation${RST}"
  echo -e "  ${DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RST}"
  echo
  echo -e "  ${BOLD}Schedule:${RST} ${CYN}${title}${RST}"
  echo -e "  ${BOLD}Cron:${RST}      ${DIM}${expr}${RST}"
  echo -e "  ${BOLD}Komut:${RST}     ${DIM}crisp all${RST}"
  echo
  echo -e "  ${DIM}Registered via Hermes cron job system.${RST}"
  echo
  printf "  ${BCYN}Confirm? (y/n): ${RST}"
  read -r confirm

  case "$confirm" in
    y|Y|yes)
      echo
      echo -e "  ${CYN}вҶ’ creating cron job...${RST}"

      # Create cronjob via hermes
      local cron_output
      cron_output=$(hermes cron create \
        --name "crisp-auto-update" \
        --deliver local \
        "$expr" \
        "Run 'crisp all' to update all modules. Report results." \
        2>&1) || true

      echo -e "  ${GRN}вң“ Cron job created!${RST}"
      echo
      echo -e "  ${DIM}Output:${RST}"
      echo -e "  ${DIM}${cron_output}${RST}"
      ;;
    *)
      echo -e "  ${YEL}вҡ  Cancelled${RST}"
      ;;
  esac

  sleep 2
}

