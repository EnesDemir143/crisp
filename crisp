#!/usr/bin/env bash
# в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
# в”Ӯ  crisp  вҖ” keep everything up-to-date, elegantly         в”Ӯ
# в”Ӯ  v1.0.0                                                 в”Ӯ
# в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
#
# Usage:  crisp                  вҶ’ interactive menu
#         crisp all              вҶ’ run all modules
#         crisp <module>         вҶ’ run specific module
#         crisp cron             вҶ’ schedule auto-update
#         crisp --help           вҶ’ show help
#         crisp --version        вҶ’ show version

# ---- strict mode ----------------------------------------------------------
set -o pipefail
# NOTE: no set -e вҖ” we handle errors per-module gracefully

# ---- paths ----------------------------------------------------------------
CRISP_DIR="${CRISP_DIR:-$HOME/Documents/crisp}"
CRISP_CONF="$CRISP_DIR/crisp.conf"
CRISP_MODULES_DIR="$CRISP_DIR/modules"
CRISP_VERSION="1.0.0"
CRISP_TAGLINE="Keep everything crisp and up-to-date"

# ---- load config ----------------------------------------------------------
if [ -f "$CRISP_CONF" ]; then
  source "$CRISP_CONF"
else
  CRISP_MODULES="graphify brew pip npm"
fi

# ---- colors (modern palette) -----------------------------------------------
RST='\033[0m';    BOLD='\033[1m';   DIM='\033[2m';     ITAL='\033[3m'
UNDER='\033[4m';  BLINK='\033[5m'; REV='\033[7m'
# Regular
BLK='\033[0;30m'; RED='\033[0;31m'; GRN='\033[0;32m'; YEL='\033[0;33m'
BLU='\033[0;34m'; MAG='\033[0;35m'; CYN='\033[0;36m'; WHT='\033[0;37m'
# Bright
BBLK='\033[1;90m'; BRED='\033[1;91m'; BGRN='\033[1;92m'; BYEL='\033[1;93m'
BBLU='\033[1;94m'; BMAG='\033[1;95m'; BCYN='\033[1;96m'; BWHT='\033[1;97m'
# Backgrounds
BG_BLK='\033[40m'; BG_RED='\033[41m'; BG_GRN='\033[42m'; BG_YEL='\033[43m'
BG_BLU='\033[44m'; BG_MAG='\033[45m'; BG_CYN='\033[46m'; BG_WHT='\033[47m'

# ---- terminal helpers ------------------------------------------------------
term_width()  { tput cols 2>/dev/null || echo 80; }
term_height() { tput lines 2>/dev/null || echo 24; }
hide_cursor() { printf '\033[?25l'; }
show_cursor() { printf '\033[?25h'; }
cursor_to()   { printf '\033[%d;%dH' "$1" "$2"; }
clear_screen() { printf '\033[2J\033[H'; }
clear_line()  { printf '\033[2K'; }
cursor_up()   { printf '\033[%dA' "${1:-1}"; }
cursor_down() { printf '\033[%dB' "${1:-1}"; }

# ---- trap setup ------------------------------------------------------------
cleanup() {
  show_cursor
  printf '\n\n'
  exit 0
}
trap cleanup EXIT INT TERM

# ---- helpers ---------------------------------------------------------------
_module_path()  { echo "$CRISP_MODULES_DIR/$1.sh"; }
_module_count() { echo "$CRISP_MODULES" | wc -w | tr -d ' '; }

_module_desc() {
  case "$1" in
    graphify) echo "Update graphify (knowledge graph + version)" ;;
    brew)     echo "brew update + brew upgrade" ;;
    pip)      echo "pip self-upgrade + outdated packages" ;;
    pipx)     echo "pipx upgrade-all (marker-pdf, pytest, etc.)" ;;
    npm)      echo "npm global packages" ;;
    npx)      echo "clear npx cache (stale packages)" ;;
    uv)       echo "uv self update + uv tool upgrade --all" ;;
    hermes)   echo "hermes agent update" ;;
    repos)    echo "git pull on all starred+cloned repos" ;;
    code)     echo "VS Code extensions update" ;;
    cargo)    echo "cargo installed tools" ;;
    stars)    echo "Generate STARRED_REPOS.md from GitHub stars" ;;
    scan)     echo "Deep scan: read READMEs, detect installs" ;;
    *)        echo "custom module" ;;
  esac
}

# ---- run a single module ---------------------------------------------------
_run_module() {
  local name="$1" silent="${2:-false}"
  local path; path="$(_module_path "$name")"

  if [ ! -f "$path" ]; then
    [[ "$silent" != "true" ]] && echo -e "  ${RED}вң— Module '${name}' not found${RST}"
    return 1
  fi

  source "$path"

  if declare -F "crisp_${name}_run" >/dev/null 2>&1; then
    [[ "$silent" != "true" ]] && echo -e "  ${CYN}[${name}]${RST}"
    if "crisp_${name}_run"; then
      [[ "$silent" != "true" ]] && echo -e "    ${GRN}вң“ done${RST}"
      return 0
    else
      [[ "$silent" != "true" ]] && echo -e "    ${YEL}вҡ  completed with warnings${RST}"
      return 0  # don't fail on module errors
    fi
  else
    [[ "$silent" != "true" ]] && echo -e "  ${RED}вң— No run function for '${name}'${RST}"
    return 1
  fi
}

# ---- run all modules -------------------------------------------------------
_run_all_modules() {
  clear_screen
  echo
  echo -e "  ${BOLD}${BCYN}crisp${RST} ${BOLD}вҖ” starting updates...${RST} ${DIM}$(date '+%H:%M')${RST}"
  echo -e "  ${DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RST}"
  echo

  local start_time; start_time=$(date +%s)
  local ran=0 failed=0
  local total; total=$(_module_count)

  for m in $CRISP_MODULES; do
    local path="$(_module_path "$m")"
    if [ -f "$path" ]; then
      if _run_module "$m"; then
        ran=$((ran + 1))
      else
        failed=$((failed + 1))
      fi
    fi
  done

  local end_time elapsed
  end_time=$(date +%s)
  elapsed=$((end_time - start_time))

  echo
  echo -e "  ${DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RST}"
  if [ $failed -eq 0 ]; then
    echo -e "  ${BGRN}${BLK} вң“ crisp done ${RST} вҖ” ${ran}/${total} modules, ${elapsed}s"
  else
    echo -e "  ${BYEL}${BLK} вҡ  crisp done ${RST} вҖ” ${ran} ok, ${failed} warning, ${elapsed}s"
  fi
  echo
}

