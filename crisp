main() {
  local cmd="${1:-}"

  case "$cmd" in
    --help|-h)
      _usage
      ;;
    --version|-v)
      _show_version
      ;;
    list)
      echo -e "${BOLD}Available modules:${RST}"
      echo
      for m in $CRISP_MODULES; do
        if [ -f "$(_module_path "$m")" ]; then
          local desc; desc=$(_module_desc "$m")
          echo -e "  ${CYN}${m}${RST} ${DIM}вҖ” ${desc}${RST}"
        fi
      done
      echo
      echo -e "${DIM}Enabled in config:${RST} $CRISP_MODULES"
      echo -e "${DIM}Config file:${RST} $CRISP_CONF"
      ;;
    all)
      _run_all_modules
      ;;
    quick)
      _run_quick_update
      ;;
    stars)
      _run_stars_report
      ;;
    cron)
      _menu_cron_schedule
      ;;
    "")
      _interactive_menu
      ;;
    *)
      # Run specific module
      echo -e "${BOLD}[${cmd}]${RST}"
      _run_module "$cmd"
      ;;
  esac
}

main "$@"
