# ---- menu data -------------------------------------------------------------
MENU_ITEMS=(
  "all:Run All Updates:Run all modules sequentially"
  "quick:Quick Update (brew/pip/npm):Update core package managers only"
  "stars:Generate Star Report:Generate STARRED_REPOS.md from GitHub stars"
  "cron:Schedule Auto-Update:Schedule recurring auto-updates"
  "config:Configure Modules:Choose which modules to run"
  "help:Help & About:Help and version info"
)

_menu_count() { echo "${#MENU_ITEMS[@]}"; }

_get_menu_item() {
  local idx=$1 field=$2
  local item="${MENU_ITEMS[$idx]}"
  case $field in
    id)    echo "$item" | cut -d: -f1 ;;
    title) echo "$item" | cut -d: -f2 ;;
    desc)  echo "$item" | cut -d: -f3 ;;
  esac
}

# ---- draw interactive menu -------------------------------------------------
# Line where menu area starts (after ASCII art + divider)
MENU_TOP_LINE=0
# Number of lines in the menu area (items + footer)
MENU_AREA_LINES=0

# Draw header once (ASCII art + divider). Returns the starting line for menu items.
_draw_header() {
  clear_screen
  hide_cursor

  local w; w=$(term_width)

  # ASCII title (10 lines + tagline + blank = 12 lines)
  _draw_ascii_title

  # menu divider
  local divider; divider=$(printf 'в”Җ%.0s' $(seq 1 $w))
  echo -e "  ${DIM}${divider:0:$((w-4))}${RST}"
  echo

  # Menu items start at line 15 (12 header + 1 divider + 1 blank)
  MENU_TOP_LINE=15
}

# Draw the menu area (items + footer) at current cursor position.
# $1 = selected index (0-based)
_draw_menu_area() {
  local sel=$1
  local n; n=$(_menu_count)
  local w; w=$(term_width)

  # draw each item
  for ((i=0; i<n; i++)); do
    local num=$((i+1))
    local title="$(_get_menu_item $i title)"
    local desc="$(_get_menu_item $i desc)"

    if [ $i -eq $sel ]; then
      echo -e "  ${BCYN}в–¶ ${num}. ${title}${RST}"
      echo -e "     ${DIM}${desc}${RST}"
    else
      echo -e "  ${DIM}  ${num}.${RST} ${title}"
      echo -e "     ${DIM}${desc}${RST}"
    fi
    echo
  done

  # bottom guide
  local divider; divider=$(printf 'в”Җ%.0s' $(seq 1 $w))
  echo -e "  ${DIM}${divider:0:$((w-4))}${RST}"
  echo
  echo -e "  ${DIM}вҶ‘/вҶ“ or j/k: navigate  в”Ӯ  Enter: select  в”Ӯ  1-${n}: quick select${RST}"
  echo -e "  ${DIM}v: version           в”Ӯ  h: help     в”Ӯ  q: quit${RST}"
  echo
  echo -e "  ${DIM}v${CRISP_VERSION}  вҖў  ${CRISP_MODULES_DIR}${RST}"

  # Calculate menu area height: n items * 3 lines + 5 footer lines
  MENU_AREA_LINES=$((n * 3 + 5))
}

# Move cursor back to MENU_TOP_LINE and clear from there down
_back_to_menu() {
  printf '\033[%d;1H' "$MENU_TOP_LINE"
  printf '\033[J'  # clear from cursor to end of screen
}

# ---- interactive input handler ---------------------------------------------
read_key() {
  local key
  IFS= read -r -s -n 1 key
  local status=$?
  if [ $status -ne 0 ]; then
    echo "QUIT"
    return
  fi

  case "$key" in
    $'\x1b')  # ESC sequence
      local b1
      # Read next byte with generous timeout (bash needs time for multi-byte sequences)
      IFS= read -r -s -n 1 -t 0.5 b1
      if [ -z "$b1" ]; then
        echo "ESC"
        return
      fi
      case "$b1" in
        '['|O)  # CSI or SS3 sequence
          local b2
          IFS= read -r -s -n 1 -t 0.5 b2
          case "$b2" in
            A) echo "UP" ;;
            B) echo "DOWN" ;;
            C) echo "RIGHT" ;;
            D) echo "LEFT" ;;
            H) echo "HOME" ;;
            F) echo "END" ;;
            [0-9])  # extended sequence like [3~ (delete), [5~ (pgup)
              local b3
              IFS= read -r -s -n 1 -t 0.3 b3
              case "$b2$b3" in
                3~) echo "DELETE" ;;
                5~) echo "PGUP" ;;
                6~) echo "PGDN" ;;
                *)   echo "ESC" ;;
              esac
              ;;
            *) echo "ESC" ;;
          esac
          ;;
        *) echo "ESC" ;;
      esac
      ;;
    '') echo "ENTER" ;;
    $'\x7f'|$'\x08') echo "BACKSPACE" ;;
    q|Q) echo "QUIT" ;;
    v|V) echo "VERSION" ;;
    h|H) echo "HELP" ;;
    j|J) echo "DOWN" ;;
    k|K) echo "UP" ;;
    g|G) echo "TOP" ;;
    [1-9]) echo "NUM:$key" ;;
    *) echo "CHAR:$key" ;;
  esac
}

# ---- menu action dispatcher ------------------------------------------------
_dispatch_menu() {
  local id="$1"

  case "$id" in
    all)
      _run_all_modules
      ;;
    quick)
      _run_quick_update
      ;;
    stars)
      _run_stars_report
      ;;
    cron)
      _menu_cron_schedule
      ;;
    config)
      _menu_config_modules
      ;;
    help)
      _show_help_screen
      ;;
    *)
      echo -e "${RED}Unknown action: $id${RST}"
      ;;
  esac

  echo
  echo -e "  ${DIM}Press any key to return to menu...${RST}"
  read -r -s -n 1
}

# ---- quick update -----------------------------------------------------------
_run_quick_update() {
  clear_screen
  echo
  echo -e "  ${BOLD}${BCYN}crisp quick${RST} ${BOLD}вҖ” core package update${RST}"
  echo -e "  ${DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RST}"
  echo

  local start_time; start_time=$(date +%s)

  # Run only the core package managers
  for m in brew pip npm; do
    if echo "$CRISP_MODULES" | grep -qw "$m"; then
      _run_module "$m"
    fi
  done

  local elapsed; elapsed=$(($(date +%s) - start_time))
  echo
  echo -e "  ${GRN}вң“ Quick update done${RST} вҖ” ${elapsed}s"
  echo
}

# ---- stars report ----------------------------------------------------------
_run_stars_report() {
  clear_screen
  echo
  echo -e "  ${BOLD}${BCYN}crisp stars${RST} ${BOLD}вҖ” GitHub star report${RST}"
  echo -e "  ${DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${RST}"
