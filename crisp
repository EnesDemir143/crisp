#!/usr/bin/env bash
# crisp — keep everything up-to-date, elegantly
# v1.0.0
# Usage: crisp → interactive menu | crisp all → run all | crisp <module> → specific

set -o pipefail

# ─────────────────────────────────────────────────
# Bash version enforcement (must be FIRST)
# ─────────────────────────────────────────────────
if [[ "${BASH_VERSINFO[0]}" -lt 5 ]]; then
  printf '\033[1;31m✗ crisp requires bash 5.0+\033[0m\n'
  printf '  Current version: %s\n' "$BASH_VERSION"
  printf '  Install: brew install bash\n'
  exit 1
fi

# ─────────────────────────────────────────────────
# Source core libraries (base → ui → common)
# ─────────────────────────────────────────────────
# Resolve symlinks to find the real script directory
_real_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir; dir="$(cd "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd "$(dirname "$src")" && pwd
}
CRISP_DIR="${CRISP_DIR:-$(_real_script_dir)}"
source "$CRISP_DIR/lib/core/base.sh"
source "$CRISP_DIR/lib/core/ui.sh"
source "$CRISP_DIR/lib/core/common.sh"

# Project constants
CRISP_VERSION="1.0.0"
CRISP_TAGLINE="Keep everything crisp and up-to-date"

# Load config
if [[ -f "$CRISP_CONF" ]]; then
  source "$CRISP_CONF"
else
  CRISP_MODULES="graphify brew pip npm"
fi

# ─────────────────────────────────────────────────
# Cleanup trap
# ─────────────────────────────────────────────────
cleanup() {
  leave_alt_screen
  show_cursor
  printf '\n'
  exit 0
}
trap cleanup EXIT INT TERM

# ─────────────────────────────────────────────────
# Menu data
# ─────────────────────────────────────────────────
MENU_ITEMS=(
  "all:Run All Updates:Run all modules sequentially"
  "quick:Quick Update (brew/pip/npm):Update core package managers only"
  "repos:Local Repo Status:Check git status of local repositories"
  "cron:Schedule Auto-Update:Schedule recurring auto-updates"
  "config:Configure Modules:Choose which modules to run"
  "help:Help & About:Help and version info"
)
_menu_count() { echo "${#MENU_ITEMS[@]}"; }
_get_menu_item() {
  local i=$1 f=$2
  local item="${MENU_ITEMS[$i]}"
  case $f in
    id)    echo "$item" | cut -d: -f1 ;;
    title) echo "$item" | cut -d: -f2 ;;
    desc)  echo "$item" | cut -d: -f3 ;;
  esac
}

# ─────────────────────────────────────────────────
# Full-redraw menu (Mole-style)
# ─────────────────────────────────────────────────
_draw_menu() {
  local sel="${1:-0}"
  local h n
  h="$(term_height)"
  n="$(_menu_count)"

  # Keep the complete redraw inside the visible alternate screen. If the render
  # is taller than the terminal, the terminal scrolls; then cursor_home no
  # longer returns to the original top and old menu rows look duplicated.
  if [[ "$h" -ge $((8 + 2 + (n * 3) + 6)) ]]; then
    CRISP_HEADER_MODE=big
    CRISP_MENU_SHOW_DESCRIPTIONS=1
  elif [[ "$h" -ge $((8 + 2 + n + 6)) ]]; then
    CRISP_HEADER_MODE=big
    CRISP_MENU_SHOW_DESCRIPTIONS=0
  elif [[ "$h" -ge $((3 + 2 + (n * 3) + 6)) ]]; then
    CRISP_HEADER_MODE=text
    CRISP_MENU_SHOW_DESCRIPTIONS=1
  else
    CRISP_HEADER_MODE=text
    CRISP_MENU_SHOW_DESCRIPTIONS=0
  fi

  cursor_home
  hide_cursor
  _draw_header
  _draw_divider
  echo
  _draw_menu_items "$sel"
  _draw_footer "$(_menu_count)"
  clear_to_end
}

# ─────────────────────────────────────────────────
# Sub-screens
# ─────────────────────────────────────────────────
_show_help_screen() {
  clear_screen
  _draw_header
  _draw_divider
  section_header "USAGE"
  echo -e "    ${CYN}crisp${RST}                     interactive menu"
  echo -e "    ${CYN}crisp all${RST}                 run all enabled modules"
  echo -e "    ${CYN}crisp quick${RST}               quick update (brew/pip/npm)"
  echo -e "    ${CYN}crisp <module>${RST}            run a specific module"
  echo -e "    ${CYN}crisp cron${RST}                schedule auto-update"
  echo -e "    ${CYN}crisp list${RST}                list modules"
  echo -e "    ${CYN}crisp --dry-run${RST}           preview without changes"
  section_header "KEYBOARD SHORTCUTS"
  echo -e "    ${CYN}↑/↓ or j/k${RST}    navigate menu"
  echo -e "    ${CYN}Enter${RST}          select highlighted item"
  echo -e "    ${CYN}1-$(_menu_count)${RST}          quick select item by number"
  echo -e "    ${CYN}g${RST}              jump to top"
  echo -e "    ${CYN}v / h / q${RST}      version / help / quit"
  section_header "FILES"
  kv_label "config" "$CRISP_CONF"
  kv_label "modules" "$CRISP_MODULES_DIR"
  kv_label "data" "$CRISP_DATA_HOME"
  echo
  press_any_key 5
}

_show_version_screen() {
  clear_screen
  _draw_header
  _draw_divider
  echo
  kv_label "Version" "crisp v${CRISP_VERSION}"
  kv_label "Tagline" "$CRISP_TAGLINE"
  kv_label "OS" "$CRISP_OS"
  kv_label "Bash" "$BASH_VERSION"
  kv_label "Config" "$CRISP_CONF"
  kv_label "Modules" "$CRISP_MODULES_DIR"
  kv_label "Data" "$CRISP_DATA_HOME"
  echo
  local count; count="$(_module_count)"
  section_header "Active modules (${count})"
  for m in $CRISP_MODULES; do
    if [[ -f "$(_module_path "$m")" ]]; then
      echo -e "    ${GRN}${ICO_DOT_FILLED}${RST} ${CYN}${m}${RST} ${DIM}— $(_module_desc "$m")${RST}"
    else
      echo -e "    ${YEL}${ICO_DOT_EMPTY}${RST} ${CYN}${m}${RST} ${DIM}— $(_module_desc "$m") ${YEL}(file missing)${RST}"
    fi
  done
  echo
  press_any_key 5
}

_show_config_screen() {
  clear_screen
  section_header "${BCYN}crisp config${RST} — module configuration"
  _draw_divider
  kv_label "Config file" "$CRISP_CONF"
  echo
  section_header "Active modules"
  for m in $CRISP_MODULES; do
    local desc; desc="$(_module_desc "$m")"
    if [[ -f "$(_module_path "$m")" ]]; then
      echo -e "    ${GRN}${ICO_DOT_FILLED}${RST} ${CYN}${m}${RST} ${DIM}— ${desc}${RST}"
    else
      echo -e "    ${YEL}${ICO_DOT_EMPTY}${RST} ${CYN}${m}${RST} ${DIM}— ${desc} ${YEL}(file missing)${RST}"
    fi
  done
  echo
  section_header "All available modules"
  for m in $(_all_available_modules); do
    local desc; desc="$(_module_desc "$m")"
    if echo "$CRISP_MODULES" | grep -qw "$m"; then
      echo -e "    ${GRN}${ICO_CHECK}${RST} ${CYN}${m}${RST} ${DIM}— ${desc}${RST}"
    else
      echo -e "    ${DIM}${ICO_DOT_EMPTY} ${m} — ${desc}${RST}"
    fi
  done
  echo
  echo -e "  ${DIM}To edit: add/remove module names in ${CRISP_CONF}${RST}"
  echo
  press_any_key 5
}

# ─────────────────────────────────────────────────
# Menu dispatch
# ─────────────────────────────────────────────────
_dispatch_menu() {
  local id="$1"
  case "$id" in
    all)    _run_all_modules ;;
    quick)  _run_quick_update ;;
    repos)  show_cursor; _run_module "repos"; hide_cursor ;;
    cron)   _menu_cron_schedule ;;
    config) _show_config_screen ;;
    help)   _show_help_screen ;;
    *)      echo -e "${RED}Unknown action: ${id}${RST}" ;;
  esac
  if [[ "$id" == "all" || "$id" == "quick" ]]; then
    echo; press_any_key 5
  fi
}

# ─────────────────────────────────────────────────
# Cron scheduling submenu
# ─────────────────────────────────────────────────
CRON_PRESETS=(
  "every_5m:Every 5 minutes"
  "every_15m:Every 15 minutes"
  "every_30m:Every 30 minutes"
  "every_1h:Every 1 hour"
  "every_6h:Every 6 hours"
  "daily_09:Daily at 09:00"
  "weekly_mon:Weekly (Monday 09:00)"
  "monthly_1:Monthly (1st, 03:00)"
  "custom:Custom cron expression"
)
_cron_preset_count() { echo "${#CRON_PRESETS[@]}"; }
_cron_get_item() {
  local i=$1 f=$2
  local item="${CRON_PRESETS[$i]}"
  case $f in id) echo "$item" | cut -d: -f1 ;; title) echo "$item" | cut -d: -f2 ;; esac
}
_cron_expression() {
  case "$1" in
    every_5m) echo "*/5 * * * *" ;; every_15m) echo "*/15 * * * *" ;;
    every_30m) echo "*/30 * * * *" ;; every_1h) echo "0 * * * *" ;;
    every_6h) echo "0 */6 * * *" ;; daily_09) echo "0 9 * * *" ;;
    weekly_mon) echo "0 9 * * 1" ;; monthly_1) echo "0 3 1 * *" ;; *) echo "" ;;
  esac
}

_menu_cron_schedule() {
  local sel=0 n; n="$(_cron_preset_count)"
  while true; do
    clear_screen
    section_header "${BCYN}crisp cron${RST} — auto-update scheduler"
    _draw_divider
    echo -e "  ${DIM}How often should it run?${RST}"
    echo
    for ((i=0; i<n; i++)); do
      local title; title="$(_cron_get_item "$i" title)"
      if [[ $i -eq $sel ]]; then
        echo -e "  ${BCYN}${ICO_ARROW} ${title}${RST}"
      else
        echo -e "  ${DIM}  ${title}${RST}"
      fi
    done
    echo
    _draw_divider
    echo -e "  ${DIM}↑/↓: select  ${ICO_BULLET}  Enter: confirm  ${ICO_BULLET}  q: back${RST}"
    local key; key="$(read_key)"
    case "$key" in
      UP)   sel=$(( (sel - 1 + n) % n )) ;;
      DOWN) sel=$(( (sel + 1) % n )) ;;
      ENTER)
        local cid; cid="$(_cron_get_item "$sel" id)"
        if [[ "$cid" == "custom" ]]; then _cron_custom_input
        else _schedule_cron_job "$(_cron_get_item "$sel" title)" "$(_cron_expression "$cid")"; fi
        return ;;
      QUIT|ESC) return ;;
    esac
  done
}

_cron_custom_input() {
  clear_screen
  section_header "${BCYN}crisp cron${RST} — custom expression"
  _draw_divider
  echo -e "  ${DIM}Format: minute hour day month weekday${RST}"
  echo -e "  ${DIM}Example: */15 * * * * (every 15 min)${RST}"
  echo
  printf "  ${BCYN}Cron expression: ${RST}"
  read -r custom_expr
  [[ -z "$custom_expr" ]] && { status_warn "Cancelled"; sleep 1; return; }
  _schedule_cron_job "Custom: $custom_expr" "$custom_expr"
}

_schedule_cron_job() {
  local title="$1" expr="$2"
  if ! command -v hermes &>/dev/null; then
    clear_screen
    status_err "Hermes CLI not found!"
    echo -e "  ${DIM}Install: https://hermes-agent.nousresearch.com${RST}"
    press_any_key 5; return 1
  fi
  clear_screen
  section_header "${BCYN}crisp cron${RST} — confirm"
  _draw_divider
  kv_label "Schedule" "${CYN}${title}${RST}"
  kv_label "Cron" "${DIM}${expr}${RST}"
  kv_label "Command" "${DIM}crisp all${RST}"
  echo
  printf "  ${BCYN}Confirm? (y/n): ${RST}"
  read -r confirm
  case "$confirm" in
    y|Y|yes)
      echo; status_info "Creating cron job..."
      hermes cron create --name "crisp-auto-update" --deliver local "$expr" "Run 'crisp all' to update all modules." 2>&1 || true
      status_ok "Cron job created!" ;;
    *) status_warn "Cancelled" ;;
  esac
  sleep 2
}

# ─────────────────────────────────────────────────
# Interactive menu loop
# ─────────────────────────────────────────────────
_interactive_menu() {
  if [[ ! -t 1 ]]; then
    echo "crisp: interactive menu requires a terminal"
    exit 1
  fi

  # Enter alternate screen buffer (clean slate, restores on exit)
  enter_alt_screen
  hide_cursor

  local n sel=0 key id
  n="$(_menu_count)"
  _draw_menu "$sel"

  while true; do
    key="$(read_key)"
    case "$key" in
      UP)     sel=$(( (sel - 1 + n) % n )); _draw_menu "$sel" ;;
      DOWN)   sel=$(( (sel + 1) % n )); _draw_menu "$sel" ;;
      TOP)    sel=0; _draw_menu "$sel" ;;
      ENTER)
        id="$(_get_menu_item "$sel" id)"
        show_cursor; _dispatch_menu "$id"; hide_cursor; _draw_menu "$sel" ;;
      NUM:*)
        local num="${key#NUM:}"
        if [[ "$num" -ge 1 ]] && [[ "$num" -le "$n" ]]; then
          sel=$((num - 1))
          id="$(_get_menu_item "$sel" id)"
          show_cursor; _dispatch_menu "$id"; hide_cursor; _draw_menu "$sel"
        fi ;;
      VERSION) _show_version_screen; _draw_menu "$sel" ;;
      HELP)    show_cursor; _show_help_screen; hide_cursor; _draw_menu "$sel" ;;
      QUIT|ESC)
        leave_alt_screen; show_cursor
        echo; echo -e "  ${DIM}crisp — see you soon!${RST}"; echo
        exit 0 ;;
    esac
  done
}

# ─────────────────────────────────────────────────
# Usage
# ─────────────────────────────────────────────────
_usage() {
  echo -e "${BOLD}crisp${RST} v${CRISP_VERSION} — ${CRISP_TAGLINE}"
  echo
  echo -e "  ${DIM}Usage:${RST}"
  echo -e "    crisp                     interactive menu"
  echo -e "    crisp all                 run all enabled modules"
  echo -e "    crisp quick               quick update (brew/pip/npm)"
  echo -e "    crisp <module>            run a specific module"
  echo -e "    crisp cron                schedule auto-update"
  echo -e "    crisp list                list available modules"
  echo -e "    crisp --dry-run           preview without changes"
  echo -e "    crisp --help              show this message"
  echo -e "    crisp --version           show version"
  echo
  echo -e "  ${DIM}Modules:${RST}"
  for m in $CRISP_MODULES; do
    printf "    ${CYN}%-12s${RST} %s\n" "$m" "$(_module_desc "$m")"
  done
  echo
}

# ─────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────
main() {
  local cmd="" dry_run=false

  for arg in "$@"; do
    case "$arg" in
      --dry-run) dry_run=true ;;
      *)         cmd="$arg" ;;
    esac
  done

  [[ "$dry_run" == "true" ]] && export CRISP_DRY_RUN=true

  _ensure_xdg_dirs

  case "$cmd" in
    --help|-h)    _usage ;;
    --version|-v) echo "crisp v${CRISP_VERSION}" ;;
    list)
      echo -e "${BOLD}Available modules:${RST}"; echo
      for m in $(_all_available_modules); do
        [[ -f "$(_module_path "$m")" ]] && \
          echo -e "  ${CYN}${m}${RST} ${DIM}— $(_module_desc "$m")${RST}"
      done; echo ;;
    all)    _run_all_modules ;;
    quick)  _run_quick_update ;;
    cron)   _menu_cron_schedule ;;
    "")     _interactive_menu ;;
    *)      echo -e "${BOLD}[${cmd}]${RST}"; _run_module "$cmd" ;;
  esac
}

main "$@"
