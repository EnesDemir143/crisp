}

_show_version_screen() {
  clear_screen
  _draw_header
  _draw_divider
  echo
  kv_label "Version" "crisp v${CRISP_VERSION}"
  kv_label "Tagline" "$CRISP_TAGLINE"
  kv_label "OS" "$CRISP_OS"
  kv_label "Bash" "$BASH_VERSION"
  kv_label "Config" "$CRISP_CONF"
  kv_label "Modules" "$CRISP_MODULES_DIR"
  kv_label "Data" "$CRISP_DATA_HOME"
  echo
  local count
  count="$(_module_count)"
  section_header "Active modules (${count})"
  for m in $CRISP_MODULES; do
    if [[ -f "$(_module_path "$m")" ]]; then
      echo -e "    ${GRN}${ICO_DOT_FILLED}${RST} ${CYN}${m}${RST} ${DIM}— $(_module_desc "$m")${RST}"
    else
      echo -e "    ${YEL}${ICO_DOT_EMPTY}${RST} ${CYN}${m}${RST} ${DIM}— $(_module_desc "$m") ${YEL}(file missing)${RST}"
    fi
  done
  echo
  press_any_key 5
}

_show_config_screen() {
  clear_screen
  section_header "${BCYN}crisp config${RST} — module configuration"
  _draw_divider
  kv_label "Config file" "$CRISP_CONF"
  echo
  section_header "Active modules"
  for m in $CRISP_MODULES; do
    local desc
    desc="$(_module_desc "$m")"
    if [[ -f "$(_module_path "$m")" ]]; then
      echo -e "    ${GRN}${ICO_DOT_FILLED}${RST} ${CYN}${m}${RST} ${DIM}— ${desc}${RST}"
    else
      echo -e "    ${YEL}${ICO_DOT_EMPTY}${RST} ${CYN}${m}${RST} ${DIM}— ${desc} ${YEL}(file missing)${RST}"
    fi
  done
  echo
  section_header "All available modules"
  for m in $(_all_available_modules); do
    local desc
    desc="$(_module_desc "$m")"
    if echo "$CRISP_MODULES" | grep -qw "$m"; then
      echo -e "    ${GRN}${ICO_CHECK}${RST} ${CYN}${m}${RST} ${DIM}— ${desc}${RST}"
    else
      echo -e "    ${DIM}${ICO_DOT_EMPTY} ${m} — ${desc}${RST}"
    fi
  done
  echo
  echo -e "  ${DIM}To edit: add/remove module names in ${CRISP_CONF}${RST}"
  echo
  press_any_key 5
}

# ─────────────────────────────────────────────────
# T21: Config picker — interactive module toggle UI
# ─────────────────────────────────────────────────
_save_config_modules() {
  local new_modules="$1"
  local dir
  dir="$(dirname "$CRISP_CONF")"
  mkdir -p "$dir" 2>/dev/null
  if [[ -f "$CRISP_CONF" ]]; then
    if grep -q "^CRISP_MODULES=" "$CRISP_CONF" 2>/dev/null; then
      if [[ "$CRISP_OS" == "macos" ]]; then
        sed -i '' "s/^CRISP_MODULES=.*/CRISP_MODULES=\"${new_modules}\"/" "$CRISP_CONF"
      else
        sed -i "s/^CRISP_MODULES=.*/CRISP_MODULES=\"${new_modules}\"/" "$CRISP_CONF"
      fi
    else
      echo "CRISP_MODULES=\"${new_modules}\"" >>"$CRISP_CONF"
    fi
  else
    echo "CRISP_MODULES=\"${new_modules}\"" >"$CRISP_CONF"
  fi
  CRISP_MODULES="$new_modules"
}

_show_config_picker() {
  local -a all_modules
  while IFS= read -r f; do
    all_modules+=("$(basename "$f" .sh)")
  done < <(find "$CRISP_MODULES_DIR" -maxdepth 1 -name '*.sh' 2>/dev/null | sort)

  local -a enabled
  for m in "${all_modules[@]}"; do
    if echo " $CRISP_MODULES " | grep -q " $m "; then
      enabled+=("$m")
    fi
  done

  local sel=0 n="${#all_modules[@]}"
  while true; do
    clear_screen
    section_header "${BCYN}crisp config${RST} — interactive module picker"
    _draw_divider
    echo
    echo -e "  ${DIM}Toggle modules with Space, save with Enter${RST}"
    echo

    local m desc toggle
    local -i i
    for ((i = 0; i < n; i++)); do
      m="${all_modules[$i]}"
      desc="$(_module_desc "$m")"
      if echo "${enabled[*]}" | grep -qw "$m"; then
        toggle="${GRN}${ICO_CHECK}${RST}"
      else
        toggle="${DIM}${ICO_CROSS}${RST}"
      fi

      if [[ $i -eq $sel ]]; then
        printf '\r\033[2K'
        echo -e "  ${BCYN}${ICO_ARROW}${RST} ${toggle} ${CYN}${m}${RST} ${DIM}— ${desc}${RST}"
      else
        printf '\r\033[2K'
        echo -e "    ${toggle} ${m} ${DIM}— ${desc}${RST}"
      fi
    done

    echo
    _draw_divider
    printf '\r\033[2K'
    echo -e "  ${DIM}↑/↓: navigate  •  Space: toggle  •  Enter: save  •  q: cancel${RST}"

    local key
    key="$(read_key)"
    case "$key" in
      UP) sel=$(((sel - 1 + n) % n)) ;;
      DOWN) sel=$(((sel + 1) % n)) ;;
      "CHAR:\ ")
        m="${all_modules[$sel]}"
        local found=false
        local -a new_enabled
        for e in "${enabled[@]}"; do
          if [[ "$e" == "$m" ]]; then
            found=true
          else
            new_enabled+=("$e")
          fi
        done
        if [[ "$found" == "false" ]]; then
          new_enabled=("${enabled[@]}" "$m")
        fi
        enabled=("${new_enabled[@]}")
        ;;
      ENTER)
        local new_modules="${enabled[*]}"
        _save_config_modules "$new_modules"
        clear_screen
        section_header "${BCYN}crisp config${RST} — saved"
        _draw_divider
        echo
        status_ok "Configuration saved: ${#enabled[@]} modules active"
        echo
        press_any_key 5
        return
        ;;
      QUIT | ESC)
        return
        ;;
    esac
  done
}

# ─────────────────────────────────────────────────
# Menu dispatch
# ─────────────────────────────────────────────────
_dispatch_menu() {
  local id="$1"
  case "$id" in
    all) _run_all_modules ;;
    quick) _run_quick_update ;;
    repos)
      show_cursor
      _run_module "repos"
      hide_cursor
      ;;
    cron) _menu_cron_schedule ;;
    orphans) source "$CRISP_DIR/lib/modules/orphans.sh" && _crisp_orphans_menu "" ;;
    radar) source "$CRISP_DIR/lib/modules/radar.sh" && _crisp_run_radar ;;
    ai-health) source "$CRISP_DIR/lib/modules/ai-health.sh" && _crisp_ai_health ;;
    config) _show_config_picker ;;
    help) _show_help_screen ;;
    *) echo -e "${RED}Unknown action: ${id}${RST}" ;;
  esac
  if [[ "$id" == "all" || "$id" == "quick" ]]; then
    echo
    press_any_key 5
  fi
}

# ─────────────────────────────────────────────────
# Cron scheduling submenu
# ─────────────────────────────────────────────────
CRON_PRESETS=(
  "every_5m:Every 5 minutes"
  "every_15m:Every 15 minutes"
  "every_30m:Every 30 minutes"
  "every_1h:Every 1 hour"
  "every_6h:Every 6 hours"
  "daily_09:Daily at 09:00"
  "weekly_mon:Weekly (Monday 09:00)"
  "monthly_1:Monthly (1st, 03:00)"
  "custom:Custom cron expression"
)
_cron_preset_count() { echo "${#CRON_PRESETS[@]}"; }
_cron_get_item() {
  local i=$1 f=$2
  local item="${CRON_PRESETS[$i]}"
  case $f in id) echo "$item" | cut -d: -f1 ;; title) echo "$item" | cut -d: -f2 ;; esac
}
_cron_expression() {
  case "$1" in
    every_5m) echo "*/5 * * * *" ;; every_15m) echo "*/15 * * * *" ;;
    every_30m) echo "*/30 * * * *" ;; every_1h) echo "0 * * * *" ;;
    every_6h) echo "0 */6 * * *" ;; daily_09) echo "0 9 * * *" ;;
    weekly_mon) echo "0 9 * * 1" ;; monthly_1) echo "0 3 1 * *" ;; *) echo "" ;;
  esac
}

_menu_cron_schedule() {
  local sel=0 n
  n="$(_cron_preset_count)"
  while true; do
    clear_screen
    section_header "${BCYN}crisp cron${RST} — auto-update scheduler"
    _draw_divider
    echo -e "  ${DIM}How often should it run?${RST}"
    echo
    for ((i = 0; i < n; i++)); do
      local title
      title="$(_cron_get_item "$i" title)"
      if [[ $i -eq $sel ]]; then
        echo -e "  ${BCYN}${ICO_ARROW} ${title}${RST}"
      else
        echo -e "  ${DIM}  ${title}${RST}"
      fi
    done
    echo
    _draw_divider
    echo -e "  ${DIM}↑/↓: select  ${ICO_BULLET}  Enter: confirm  ${ICO_BULLET}  q: back${RST}"
    local key
    key="$(read_key)"
    case "$key" in
      UP) sel=$(((sel - 1 + n) % n)) ;;
      DOWN) sel=$(((sel + 1) % n)) ;;
      ENTER)
        local cid
        cid="$(_cron_get_item "$sel" id)"
        if [[ "$cid" == "custom" ]]; then
          _cron_custom_input
        else _schedule_cron_job "$(_cron_get_item "$sel" title)" "$(_cron_expression "$cid")"; fi
        return
        ;;
      QUIT | ESC) return ;;
    esac
  done
}

_cron_custom_input() {
  clear_screen
  section_header "${BCYN}crisp cron${RST} — custom expression"
  _draw_divider
  echo -e "  ${DIM}Format: minute hour day month weekday${RST}"
  echo -e "  ${DIM}Example: */15 * * * * (every 15 min)${RST}"
  echo
  printf "  ${BCYN}Cron expression: ${RST}"
  read -r custom_expr
  [[ -z "$custom_expr" ]] && {
    status_warn "Cancelled"
    sleep 1
    return
  }
  _schedule_cron_job "Custom: $custom_expr" "$custom_expr"
}

_schedule_cron_job() {
  local title="$1" expr="$2"
  if ! command -v hermes &>/dev/null; then
    clear_screen
    status_err "Hermes CLI not found!"
    echo -e "  ${DIM}Install: https://hermes-agent.nousresearch.com${RST}"
    press_any_key 5
    return 1
  fi
  clear_screen
  section_header "${BCYN}crisp cron${RST} — confirm"
  _draw_divider
  kv_label "Schedule" "${CYN}${title}${RST}"
  kv_label "Cron" "${DIM}${expr}${RST}"
  kv_label "Command" "${DIM}crisp all${RST}"
  echo
  printf "  ${BCYN}Confirm? (y/n): ${RST}"
  read -r confirm
  case "$confirm" in
    y | Y | yes)
      echo
      status_info "Creating cron job..."
      hermes cron create --name "crisp-auto-update" --deliver local "$expr" "Run 'crisp all' to update all modules." 2>&1 || true
      status_ok "Cron job created!"
      ;;
    *) status_warn "Cancelled" ;;
  esac
  sleep 2
}

# ─────────────────────────────────────────────────
# Interactive menu loop
# ─────────────────────────────────────────────────
_interactive_menu() {
  if [[ ! -t 1 ]]; then
    echo "crisp: interactive menu requires a terminal"
    exit 1
  fi

  # Enter alternate screen buffer (clean slate, restores on exit)
  enter_alt_screen
  hide_cursor

  local n sel=0 key id
  n="$(_menu_count)"
  _draw_menu "$sel"

  while true; do
    key="$(read_key)"
    case "$key" in
      UP)
        sel=$(((sel - 1 + n) % n))
        _draw_menu "$sel"
        ;;
      DOWN)
        sel=$(((sel + 1) % n))
        _draw_menu "$sel"
        ;;
      TOP)
        sel=0
        _draw_menu "$sel"
        ;;
      ENTER)
        id="$(_get_menu_item "$sel" id)"
        show_cursor
        _dispatch_menu "$id"
        hide_cursor
        _draw_menu "$sel"
        ;;
      NUM:*)
        local num="${key#NUM:}"
        if [[ "$num" -ge 1 ]] && [[ "$num" -le "$n" ]]; then
          sel=$((num - 1))
          id="$(_get_menu_item "$sel" id)"
          show_cursor
          _dispatch_menu "$id"
          hide_cursor
          _draw_menu "$sel"
        fi
        ;;
      VERSION)
        _show_version_screen
        _draw_menu "$sel"
        ;;
      HELP)
        show_cursor
        _show_help_screen
        hide_cursor
        _draw_menu "$sel"
        ;;
      QUIT | ESC)
        leave_alt_screen
        show_cursor
        echo
        echo -e "  ${DIM}crisp — see you soon!${RST}"
        echo
        exit 0
        ;;
    esac
  done
}

