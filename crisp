# ─────────────────────────────────────────────────
# Self-update (T11)
# ─────────────────────────────────────────────────
_crisp_update() {
  clear_screen
  section_header "${BCYN}crisp update${RST} — self-update"
  _draw_divider
  kv_label "Current" "v${CRISP_VERSION}"
  echo

  # Check for git remote updates first
  if command -v git &>/dev/null && [[ -d "$CRISP_HOME/.git" ]]; then
    status_info "Fetching latest changes..."
    git -C "$CRISP_HOME" fetch origin main 2>/dev/null || true
    local local_sha remote_sha
    local_sha="$(git -C "$CRISP_HOME" rev-parse HEAD)"
    remote_sha="$(git -C "$CRISP_HOME" rev-parse FETCH_HEAD 2>/dev/null || echo "")"
    if [[ -n "$remote_sha" ]] && [[ "$local_sha" == "$remote_sha" ]]; then
      status_ok "Already up-to-date (git)"
      press_any_key 5
      return 0
    fi
    status_info "Pulling latest from main..."
    if git -C "$CRISP_HOME" pull --ff-only origin main 2>&1; then
      local new_version
      new_version="$(git -C "$CRISP_HOME" describe --tags --abbrev=0 2>/dev/null || echo "v0.0.0")"
      status_ok "Updated to ${new_version}"
    else
      status_err "Failed to pull updates"
      press_any_key 5
      return 1
    fi

  elif [[ "$CRISP_OS" == "macos" ]]; then
    # brew-based install
    if command -v brew &>/dev/null && brew list --formula enesdemir/tap/crisp &>/dev/null 2>&1; then
      status_info "Upgrading via Homebrew..."
      brew upgrade enesdemir/tap/crisp || {
        status_err "Homebrew upgrade failed"
        press_any_key 5
        return 1
      }
      status_ok "Updated via Homebrew"
    else
      status_info "Re-running installer..."
      curl -fsSL https://raw.githubusercontent.com/enesdemir/crisp/main/install.sh | bash || {
        status_err "Re-install failed"
        press_any_key 5
        return 1
      }
    fi

  else
    # Linux: re-run installer
    status_info "Re-running installer..."
    curl -fsSL https://raw.githubusercontent.com/enesdemir/crisp/main/install.sh | bash || {
      status_err "Re-install failed"
      press_any_key 5
      return 1
    }
  fi

  echo
  press_any_key 5
  return 0
}

# ─────────────────────────────────────────────────
# PATH setup (T12)
# ─────────────────────────────────────────────────
_crisp_setup_path() {
  local shell_name rc_file
  shell_name="$(basename "${SHELL:-/bin/bash}")"

  # Determine the correct rc file
  case "$shell_name" in
    bash)
      if [[ -f "$HOME/.bashrc" ]]; then
        rc_file="$HOME/.bashrc"
      elif [[ -f "$HOME/.bash_profile" ]]; then
        rc_file="$HOME/.bash_profile"
      else
        rc_file="$HOME/.bashrc"
      fi
      ;;
    zsh)
      if [[ -f "$HOME/.zshrc" ]]; then
        rc_file="$HOME/.zshrc"
      elif [[ -f "$HOME/.zshenv" ]]; then
        rc_file="$HOME/.zshenv"
      else
        rc_file="$HOME/.zshrc"
      fi
      ;;
    fish)
      rc_file="$HOME/.config/fish/config.fish"
      mkdir -p "$(dirname "$rc_file")"
      ;;
    *)
      rc_file="$HOME/.bashrc"
      shell_name="bash"
      ;;
  esac

  # Find which directory crisp is in
  local crisp_bin
  crisp_bin="$(dirname "$(command -v crisp 2>/dev/null || readlink -f "$(command -v crisp 2>/dev/null || echo "$CRISP_DIR/crisp")")")"

  # Check if already in PATH config
  if grep -q "${crisp_bin}" "$rc_file" 2>/dev/null; then
    echo -e "  ${GRN}${ICO_OK}${RST} ${crisp_bin} already in ${rc_file}"
    echo
    echo -e "  ${DIM}Run 'source ${rc_file}' or restart shell.${RST}"
    return 0
  fi

  # Append to rc file
  {
    echo ""
    echo "# crisp PATH — added by crisp setup-path"
    echo "export PATH=\"${crisp_bin}:\$PATH\""
  } >>"$rc_file"

  echo -e "  ${GRN}${ICO_OK}${RST} Added to ${rc_file}"
  echo -e "  ${CYN}Run 'source ${rc_file}' or restart shell.${RST}"
  echo
}

# ─────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────
main() {
  local cmd="" dry_run=false

  for arg in "$@"; do
    case "$arg" in
      --dry-run) dry_run=true ;;
      *) [[ -z "$cmd" ]] && cmd="$arg" ;;
    esac
  done

  [[ "$dry_run" == "true" ]] && export CRISP_DRY_RUN=true

  _ensure_xdg_dirs

  case "$cmd" in
    --help | -h) _usage ;;
    --version | -v)
      local commit=""
      if command -v git &>/dev/null && git -C "$CRISP_DIR" rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
        commit="$(git -C "$CRISP_DIR" rev-parse --short HEAD)"
      fi
      echo "crisp ${CRISP_VERSION}${commit:+ ($commit)}"
      ;;
    list)
      echo -e "${BOLD}Available modules:${RST}"
      echo
      for m in $(_all_available_modules); do
        [[ -f "$(_module_path "$m")" ]] &&
          echo -e "  ${CYN}${m}${RST} ${DIM}— $(_module_desc "$m")${RST}"
      done
      echo
      ;;
    all) _run_all_modules ;;
    quick) _run_quick_update ;;
    cron) _menu_cron_schedule ;;
    config) _show_config_picker ;;
    update) _crisp_update ;;
    setup-path) _crisp_setup_path ;;
    scan-orphans) source "$CRISP_DIR/lib/modules/orphans.sh" && _crisp_scan_orphans ;;
    check-orphans) source "$CRISP_DIR/lib/modules/orphans.sh" && _crisp_check_orphans ;;
    update-orphans) source "$CRISP_DIR/lib/modules/orphans.sh" && _crisp_update_orphans ;;
    list-orphans) source "$CRISP_DIR/lib/modules/orphans.sh" && _crisp_list_orphans ;;
    uninstall) source "$CRISP_DIR/lib/modules/orphans.sh" && _crisp_uninstall "$@" ;;
    orphans) source "$CRISP_DIR/lib/modules/orphans.sh" && _crisp_orphans_menu "$2" ;;
    radar) source "$CRISP_DIR/lib/modules/radar.sh" && _crisp_run_radar ;;
    ai-health) source "$CRISP_DIR/lib/modules/ai-health.sh" && _crisp_ai_health ;;
    "") _interactive_menu ;;
    *)
      echo -e "${BOLD}[${cmd}]${RST}"
      _run_module "$cmd"
      ;;
  esac
}

main "$@"
